#!/Users/nikenike/.hermes/hermes-agent/venv/bin/python
import argparse
import datetime as dt
import hashlib
import json
import os
import re
import sys
import urllib.error
import urllib.request
from pathlib import Path

API = "https://discord.com/api/v10"
MAX_SECONDS_DEFAULT = 24 * 60 * 60
ADMINISTRATOR = 1 << 3
MODERATE_MEMBERS = 1 << 40


def load_env() -> dict:
    env = dict(os.environ)
    homes = []
    if env.get("HERMES_HOME"):
        homes.append(Path(env["HERMES_HOME"]))
    homes.append(Path.home() / ".hermes")
    for home in homes:
        p = home / ".env"
        if not p.exists():
            continue
        for line in p.read_text(encoding="utf-8", errors="replace").splitlines():
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, v = line.split("=", 1)
            env.setdefault(k.strip(), v.strip())
    return env


ENV = load_env()
TOKEN = ENV.get("DISCORD_BOT_TOKEN", "").strip()
HOME = Path(ENV.get("HERMES_HOME") or Path.home() / ".hermes")
STATE_DIR = HOME / "local" / "discord-freeze"
AUDIT = STATE_DIR / "audit.jsonl"
ALLOWED_GUILDS = {
    g.strip()
    for g in ENV.get("DISCORD_ALLOWED_GUILDS", "").split(",")
    if g.strip()
}


class DiscordError(RuntimeError):
    pass


def request(method: str, path: str, body: dict | None = None):
    if not TOKEN:
        raise DiscordError("DISCORD_BOT_TOKEN is not configured")
    data = None if body is None else json.dumps(body).encode("utf-8")
    req = urllib.request.Request(
        API + path,
        data=data,
        method=method,
        headers={
            "Authorization": f"Bot {TOKEN}",
            "Content-Type": "application/json",
            "User-Agent": "nikechan-hermes-discord-freeze/1.0",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            if resp.status == 204:
                return None
            return json.loads(resp.read().decode("utf-8"))
    except urllib.error.HTTPError as e:
        body_text = e.read().decode("utf-8", errors="replace")
        raise DiscordError(f"Discord API {e.code}: {body_text}") from e


def parse_duration(value: str) -> int:
    s = value.strip().lower()
    m = re.fullmatch(r"(\d+)([smhd])", s)
    if not m:
        raise ValueError("duration must look like 30m, 2h, or 1d")
    n = int(m.group(1))
    unit = m.group(2)
    return n * {"s": 1, "m": 60, "h": 3600, "d": 86400}[unit]


def assert_allowed_guild(guild_id: str):
    if ALLOWED_GUILDS and guild_id not in ALLOWED_GUILDS:
        allowed = ", ".join(sorted(ALLOWED_GUILDS))
        raise DiscordError(
            f"requested guild is outside this profile's allowed Discord server. "
            f"guild_id={guild_id} allowed_guilds={allowed}"
        )


def roles(guild_id: str) -> dict:
    return {r["id"]: r for r in request("GET", f"/guilds/{guild_id}/roles")}


def member(guild_id: str, user_id: str) -> dict:
    return request("GET", f"/guilds/{guild_id}/members/{user_id}")


def permissions_for(guild_id: str, user_id: str, role_map: dict) -> int:
    m = member(guild_id, user_id)
    perms = int(role_map[guild_id]["permissions"])
    for rid in m.get("roles", []):
        perms |= int(role_map.get(rid, {}).get("permissions", 0))
    return perms


def action_path(action_id: str) -> Path:
    return STATE_DIR / f"{action_id}.json"


def write_audit(entry: dict):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    with AUDIT.open("a", encoding="utf-8") as f:
        f.write(json.dumps(entry, ensure_ascii=False) + "\n")


def cmd_prepare(args):
    assert_allowed_guild(args.guild)
    seconds = parse_duration(args.duration)
    max_seconds = int(os.getenv("DISCORD_FREEZE_MAX_SECONDS", str(MAX_SECONDS_DEFAULT)))
    if seconds <= 0 or seconds > max_seconds:
        raise DiscordError(f"duration exceeds policy max ({max_seconds} seconds)")
    if not args.reason.strip():
        raise DiscordError("reason is required")

    guild = request("GET", f"/guilds/{args.guild}")
    role_map = roles(args.guild)
    bot = request("GET", "/users/@me")
    target = member(args.guild, args.user_id)
    target_user = target.get("user", {})

    if args.user_id == guild.get("owner_id"):
        raise DiscordError("server owner is protected and cannot be frozen")
    target_perms = permissions_for(args.guild, args.user_id, role_map)
    if target_perms & ADMINISTRATOR:
        raise DiscordError("administrator is protected and cannot be frozen")
    bot_perms = permissions_for(args.guild, bot["id"], role_map)
    if not (bot_perms & MODERATE_MEMBERS):
        raise DiscordError("bot lacks Moderate Members permission")

    until = dt.datetime.now(dt.timezone.utc) + dt.timedelta(seconds=seconds)
    raw = f"{args.guild}:{args.user_id}:{args.duration}:{args.reason}:{dt.datetime.now(dt.timezone.utc).isoformat()}"
    action_id = hashlib.sha256(raw.encode()).hexdigest()[:16]
    action = {
        "action_id": action_id,
        "guild_id": args.guild,
        "guild_name": guild.get("name"),
        "target_user_id": args.user_id,
        "target_username": target_user.get("username"),
        "duration": args.duration,
        "duration_seconds": seconds,
        "until": until.isoformat().replace("+00:00", "Z"),
        "reason": args.reason,
        "executor_id": args.executor_id,
        "source_message_id": args.source_message_id,
        "status": "prepared",
        "created_at": dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z"),
    }
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    action_path(action_id).write_text(json.dumps(action, ensure_ascii=False, indent=2), encoding="utf-8")
    write_audit({**action, "event": "prepare"})
    print(json.dumps(action, ensure_ascii=False, indent=2))


def cmd_apply(args):
    p = action_path(args.action_id)
    if not p.exists():
        raise DiscordError(f"unknown action_id: {args.action_id}")
    action = json.loads(p.read_text(encoding="utf-8"))
    assert_allowed_guild(action["guild_id"])
    if action.get("status") != "prepared":
        raise DiscordError(f"action is not prepared: {action.get('status')}")
    body = {
        "communication_disabled_until": action["until"],
    }
    request(
        "PATCH",
        f"/guilds/{action['guild_id']}/members/{action['target_user_id']}",
        body=body,
    )
    action["status"] = "applied"
    action["approval_message_id"] = args.approval_message_id
    action["applied_at"] = dt.datetime.now(dt.timezone.utc).isoformat().replace("+00:00", "Z")
    p.write_text(json.dumps(action, ensure_ascii=False, indent=2), encoding="utf-8")
    write_audit({**action, "event": "apply"})
    print(json.dumps(action, ensure_ascii=False, indent=2))


def main():
    parser = argparse.ArgumentParser(description="Prepare/apply Discord timeout with policy checks.")
    sub = parser.add_subparsers(dest="cmd", required=True)
    p = sub.add_parser("prepare")
    p.add_argument("--guild", required=True)
    p.add_argument("--user-id", required=True)
    p.add_argument("--duration", required=True)
    p.add_argument("--reason", required=True)
    p.add_argument("--executor-id", default="")
    p.add_argument("--source-message-id", default="")
    a = sub.add_parser("apply")
    a.add_argument("--action-id", required=True)
    a.add_argument("--approval-message-id", default="")
    args = parser.parse_args()
    try:
        if args.cmd == "prepare":
            cmd_prepare(args)
        elif args.cmd == "apply":
            cmd_apply(args)
    except (DiscordError, ValueError) as e:
        print(json.dumps({"error": str(e)}, ensure_ascii=False), file=sys.stderr)
        sys.exit(2)


if __name__ == "__main__":
    main()
